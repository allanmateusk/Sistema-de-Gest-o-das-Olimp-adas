# Copie para .env na raiz e ajuste. O docker-compose usa estas variáveis.

# Obrigatório em produção: chave longa e aleatória (não use o valor de exemplo).
JWT_SECRET=changeMeDevSecretKeyAtLeast32CharactersLong!!

# Contas iniciais (só se a base ainda não tiver utilizadores). Desative em produção.
# SGO_SEED_DEMO_ACCOUNTS=true
# SGO_SEED_ADMIN_PASSWORD=
# SGO_SEED_USUARIO_PASSWORD=
